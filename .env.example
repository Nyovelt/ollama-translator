# ---- Upstream translation API (OpenAI-compatible) ----
# Base URL WITHOUT the /v1 suffix (the server appends /v1/chat/completions).
TRANSLATE_API_BASE_URL=https://your-upstream.example.com
# Secret API key. Sent as "Authorization: Bearer <key>". Never commit the real value.
TRANSLATE_API_KEY=sk-replace-me
# Model id exposed by the upstream (GET /v1/models).
TRANSLATE_MODEL=gemma-4-E4B-it-qat-UD-Q4_K_XL.gguf
# Upstream context window (tokens). Used to derive chunk sizing for long text.
# Set to your upstream's REAL available context (the reference upstream is 4096).
TRANSLATE_CTX_SIZE=4096

# ---- Queue / concurrency tuning ----
# Max concurrent upstream calls. Keep <= the upstream "parallel" limit (8).
WORKER_CONCURRENCY=8
# Max jobs allowed to wait in the queue; new requests beyond this get HTTP 429.
QUEUE_MAX_SIZE=100
# Per-upstream-request timeout in milliseconds.
REQUEST_TIMEOUT=60000
# Retries per chunk on network/timeout/5xx/429 (with exponential backoff).
MAX_RETRIES=3
# Optional: override chunk size in characters (default: floor(CTX_SIZE / 4)).
# CHUNK_CHAR_BUDGET=8192

# ---- Server ----
PORT=3000
# SQLite database file. Put it on the mounted volume so data persists.
DB_PATH=/data/translations.db
